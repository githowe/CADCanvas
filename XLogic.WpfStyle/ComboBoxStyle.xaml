<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 下拉列表框模板 -->
    <ControlTemplate x:Key="下拉列表框" TargetType="ComboBox">
        <Grid>
            <!-- 下拉按钮 -->
            <ToggleButton x:Name="Toggle" Background="#3c3c3c"
                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                        <!-- 外框 -->
                        <Border x:Name="ToggleBorder" Background="{TemplateBinding Background}">
                            <!-- 箭头 -->
                            <Grid Width="25" HorizontalAlignment="Right">
                                <Image x:Name="Arrow" Source="Image/ArrowDown.png" Width="15" Height="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </ToggleButton.Template>
            </ToggleButton>
            <!-- 文本 -->
            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}" IsHitTestVisible="False" Margin="6,0,29,0" VerticalAlignment="Center" TextBlock.Foreground="White"/>
            <!-- 弹出框 -->
            <Popup x:Name="PART_Popup" AllowsTransparency="True" Width="{TemplateBinding Width}" MaxHeight="250"
                   IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                   PopupAnimation="Slide" Placement="Bottom">
                <ScrollViewer x:Name="ScrollViewer" Style="{StaticResource ListBoxSV}" Background="#141414">
                    <ItemsPresenter/>
                </ScrollViewer>
            </Popup>
        </Grid>
        <!-- 触发器 -->
        <ControlTemplate.Triggers>
            <!-- 禁用 -->
            <Trigger Property="IsEnabled" Value="false">
                <Setter Property="Opacity" Value="0.3"/>
            </Trigger>
            <!-- 鼠标悬停 -->
            <Trigger SourceName="Toggle" Property="IsMouseOver" Value="True">
                <Setter TargetName="Toggle" Property="Background" Value="#505050"/>
            </Trigger>
            <!-- 鼠标按下 -->
            <Trigger SourceName="Toggle" Property="IsPressed" Value="True">
                <Setter TargetName="Toggle" Property="Background" Value="#3c3c3c"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- 下拉列表框模板 -->
    <ControlTemplate x:Key="下拉列表框长" TargetType="ComboBox">
        <Grid>
            <!-- 下拉按钮 -->
            <ToggleButton x:Name="Toggle" Background="#3c3c3c"
                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                        <!-- 外框 -->
                        <Border x:Name="ToggleBorder" Background="{TemplateBinding Background}">
                            <!-- 箭头 -->
                            <Grid Width="25" HorizontalAlignment="Right">
                                <Image x:Name="Arrow" Source="Image/ArrowDown.png" Width="15" Height="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </ToggleButton.Template>
            </ToggleButton>
            <!-- 文本 -->
            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}" IsHitTestVisible="False" Margin="6,0,29,0" VerticalAlignment="Center" TextBlock.Foreground="White"/>
            <!-- 弹出框 -->
            <Popup x:Name="PART_Popup" AllowsTransparency="True" Width="{TemplateBinding Width}" MaxHeight="500"
               IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
               PopupAnimation="Slide" Placement="Bottom">
                <ScrollViewer x:Name="ScrollViewer" Style="{StaticResource ListBoxSV}" Background="#141414">
                    <ItemsPresenter/>
                </ScrollViewer>
            </Popup>
        </Grid>
        <!-- 触发器 -->
        <ControlTemplate.Triggers>
            <!-- 禁用 -->
            <Trigger Property="IsEnabled" Value="false">
                <Setter Property="Opacity" Value="0.3"/>
            </Trigger>
            <!-- 鼠标悬停 -->
            <Trigger SourceName="Toggle" Property="IsMouseOver" Value="True">
                <Setter TargetName="Toggle" Property="Background" Value="#505050"/>
            </Trigger>
            <!-- 鼠标按下 -->
            <Trigger SourceName="Toggle" Property="IsPressed" Value="True">
                <Setter TargetName="Toggle" Property="Background" Value="#3c3c3c"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- 可编辑下拉列表框模板 -->
    <ControlTemplate x:Key="可编辑下拉列表框" TargetType="ComboBox">
        <Grid>
            <!-- 下拉按钮 -->
            <ToggleButton x:Name="Toggle" BorderBrush="#586983"
                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                        <!-- 外框 -->
                        <Border BorderThickness="1" BorderBrush="{TemplateBinding BorderBrush}" Background="#3B4453">
                            <!-- 箭头 -->
                            <Grid Width="25" HorizontalAlignment="Right">
                                <Image Source="Image/ArrowDown.png" Width="15" Height="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </ToggleButton.Template>
            </ToggleButton>
            <!-- 文本输入框 -->
            <TextBox x:Name="PART_EditableTextBox" BorderThickness="0" Margin="1,1,23,1" Padding="3,0"/>
            <!-- 弹出框 -->
            <Popup x:Name="PART_Popup" AllowsTransparency="True" Width="{TemplateBinding Width}" MaxHeight="230"
                   IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                   PopupAnimation="Slide" Placement="Bottom">
                <ScrollViewer x:Name="ScrollViewer" Style="{StaticResource ListBoxSV}" Background="#29323E">
                    <ItemsPresenter/>
                </ScrollViewer>
            </Popup>
        </Grid>
        <ControlTemplate.Triggers>
            <!-- 鼠标悬停 -->
            <Trigger Property="IsMouseOver" Value="true">
                <Setter Property="BorderBrush" TargetName="Toggle" Value="#7B94B8"/>
            </Trigger>
            <!-- 获取输入焦点时 -->
            <Trigger SourceName="PART_EditableTextBox" Property="IsKeyboardFocused" Value="true">
                <Setter Property="BorderBrush" TargetName="Toggle" Value="#6FAAFF"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- 下拉列表框样式 -->
    <Style TargetType="ComboBox">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <!-- 高度 -->
        <Setter Property="Height" Value="25"/>
        <!-- 模板 -->
        <Setter Property="Template" Value="{StaticResource 下拉列表框}"/>
        <Style.Triggers>
            <Trigger Property="IsEditable" Value="True">
                <Setter Property="Template" Value="{StaticResource 可编辑下拉列表框}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="LengthComboBox" TargetType="ComboBox">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <!-- 高度 -->
        <Setter Property="Height" Value="25"/>
        <!-- 模板 -->
        <Setter Property="Template" Value="{StaticResource 下拉列表框长}"/>
        <Style.Triggers>
            <Trigger Property="IsEditable" Value="True">
                <Setter Property="Template" Value="{StaticResource 可编辑下拉列表框}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 下拉列表项样式 -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <!-- 高度 -->
        <Setter Property="Height" Value="25"/>
        <!-- 前景色 -->
        <Setter Property="Foreground" Value="#8c8c8c"/>
        <!-- 模板 -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <!-- 外框 -->
                    <Border Height="{TemplateBinding Height}" x:Name="Border" Background="Transparent">
                        <ContentPresenter VerticalAlignment="Center" Margin="6,1,16,0"/>
                    </Border>
                    <!-- 触发器 -->
                    <ControlTemplate.Triggers>
                        <!-- 已选中 -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#20FFFFFF"/>
                        </Trigger>
                        <!-- 鼠标悬停 -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#40FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
</ResourceDictionary>