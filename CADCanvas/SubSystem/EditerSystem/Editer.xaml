<UserControl x:Class="CADCanvas.SubSystem.EditerSystem.Editer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CADCanvas.SubSystem.EditerSystem"
             xmlns:wc="clr-namespace:XLogic.WpfControl;assembly=XLogic.WpfControl"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid x:Name="MainGrid" Background="#101010">
        <!-- 分成三行：工具栏、文档区、状态栏 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition />
            <RowDefinition Height="0"/>
        </Grid.RowDefinitions>
        <!-- 工具栏背景 -->
        <Grid Background="#1E1E1E"/>
        <!-- 工具栏 -->
        <StackPanel x:Name="Stack_ToolBar" Orientation="Horizontal" HorizontalAlignment="Left">
            <Button x:Name="Tool_Line" Style="{StaticResource ToolBarButton}" ToolTip="绘制直线" Width="30" Height="30">
                <Button.Content>
                    <Image Source="Image/Line.png" Height="16" Width="16"/>
                </Button.Content>
            </Button>
            <Button x:Name="Tool_Circle" Style="{StaticResource ToolBarButton}" ToolTip="绘制圆形" Width="30" Height="30">
                <Button.Content>
                    <Image Source="Image/Circle.png" Height="16" Width="16"/>
                </Button.Content>
            </Button>
        </StackPanel>
        <!-- 文档区分两列：编辑区、属性面板 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition x:Name="RightArea" Width="0"/>
            </Grid.ColumnDefinitions>
            <!-- 编辑区 -->
            <Grid Grid.Column="0">
                <Grid x:Name="DocBox">
                    <Grid x:Name="PaperBox" ClipToBounds="True"/>
                    <Grid x:Name="LayerBox"/>
                    <Grid x:Name="Layer_Mouse" Background="Transparent"/>
                </Grid>
            </Grid>
            <!-- 属性面板 -->
            <Grid Background="#262626" Grid.Column="2">
                <Grid.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Duration="0:0:0.5" To="1" Storyboard.TargetName="PropertyScrollBar" Storyboard.TargetProperty="Opacity"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Duration="0:0:0.5" To="0" Storyboard.TargetName="PropertyScrollBar" Storyboard.TargetProperty="Opacity" BeginTime="0:0:2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>
                <Grid x:Name="PropertyPanelBox"/>
                <ScrollBar x:Name="PropertyScrollBar" Orientation="Vertical" HorizontalAlignment="Right" Tag="0" Width="10" Opacity="0" Grid.Row="1"
                           SmallChange="1" ViewportSize="10" Minimum="0" Maximum="0"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>